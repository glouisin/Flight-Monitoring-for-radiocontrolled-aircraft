#include <Wire.h>
#include <Adafruit_LIS3DH.h>
#include <SD.h>
#include <SoftwareSerial.h>
#include <TinyGPSPlus.h>

#define MS5607_ADDRESS 0x76
#define SENSOR_PIN 6
#define CHIP_SELECT 10
#define GPS_BUFFER_SIZE 100
char gpsBuffer[GPS_BUFFER_SIZE];
int gpsBufferIndex = 0;

SoftwareSerial gpsSerial(2, 3); // RX, TX  GPS
SoftwareSerial rf(5, 7);        // RX, TX  LoRa
Adafruit_LIS3DH lis = Adafruit_LIS3DH();
TinyGPSPlus gps;

unsigned char buffer[64];
int count = 0;
File dataFile;


uint16_t C[7];
unsigned long startime=millis();
float time;

char nfgps[] = "ngptest.txt"; // 8 caractères max pour le nom
void setup() {
  Serial.begin(9600);
  Wire.begin();
  gpsSerial.begin(9600);
  //rf.begin(9600);
  delay(2000);

  Serial.print(F("Initialisation de la carte SD..."));
  if (!SD.begin(CHIP_SELECT)) {
    Serial.println(F("Erreur d'initialisation!"));
    return;
  }
  Serial.println(F("Carte SD OK."));

  dataFile = SD.open(nfgps, FILE_WRITE);
  if (dataFile) {
    Serial.println("Création/ouverture fichier gps réussie!");
    dataFile.println(F("=== Debut des donnees GPS ==="));
    dataFile.close();
  } else {
    Serial.println(F("Erreur ouverture fichier gps !"));
  }

  if (!lis.begin(0x19)) {
    Serial.println(F("LIS3DH non detecte!"));
    while (1);
  }
  lis.setRange(LIS3DH_RANGE_4_G);
  Serial.println("Acceleromètre OK.");


  for (uint8_t i = 1; i <= 6; i++) {
    Wire.beginTransmission(MS5607_ADDRESS);
    Wire.write(0xA2 + (i - 1) * 2);
    Wire.endTransmission();
    Wire.requestFrom(MS5607_ADDRESS, 2);
    if (Wire.available() == 2) {
      C[i] = (Wire.read() << 8) | Wire.read();
    }
  }
  rf.println(F("Hello depuis Arduino!"));
  Serial.println(F("start"));
}

void loop() {
  rf.listen();
  rf.println(F("--------------------------"));
  Serial.println(F("--------------------------"));

  float humidity = ((((RCtime(SENSOR_PIN)) *pow(10,-6)/1e6) - 163.33e-12) / 3.33e-11);
  rf.print(F("Humidite: ")); rf.println(humidity);
  Serial.print(F("Humidite: ")); Serial.println(humidity);

  // Température
  Wire.beginTransmission(MS5607_ADDRESS);
  Wire.write(0x58);
  Wire.endTransmission();
  delay(10);
  Wire.beginTransmission(MS5607_ADDRESS);
  Wire.write(0x00);
  Wire.endTransmission(false);
  Wire.requestFrom(MS5607_ADDRESS, 3);
  uint32_t D2 = 0;
  if (Wire.available() == 3) {
    D2 = ((uint32_t)Wire.read() << 16) | ((uint32_t)Wire.read() << 8) | Wire.read();
  }
  int32_t dT = D2 - ((uint16_t)C[5] << 8);
  int32_t TEMP = 2000 + ((uint32_t)dT * C[6]) / 8388608;
  int32_t T2 = (dT * dT) / 2147483648L;
  TEMP -= T2;

  float temperature = TEMP / 100.0;
  rf.print(F("Temp (C): ")); rf.println(temperature);
  Serial.print(F("Temp (C): ")); Serial.println(temperature);

  // Accéléromètre

  sensors_event_t event;
  lis.getEvent(&event);
  time = (millis()-startime)/1000;
  Serial.print(time, 4); Serial.print(F(", "));
  Serial.print(event.acceleration.x); Serial.print(F(", "));
  Serial.print(event.acceleration.y); Serial.print(F(", "));
  Serial.println(event.acceleration.z);
    

  
  
  // GPS
   while (gpsSerial.available()) {
    char c = gpsSerial.read();
    gps.encode(c);
  }

  if (gpsSerial.available()) {
    char c = gpsSerial.read();
    Serial.write(c); // affiche chaque caractère reçu
    gps.encode(c);
    
  }


  if (gps.location.isUpdated()) {
    Serial.println(F("===== DONNEES GPS ====="));
    Serial.print(F("Latitude   : ")); Serial.println(gps.location.lat(), 6);
    Serial.print(F("Longitude  : ")); Serial.println(gps.location.lng(), 6);
    Serial.print(F("Altitude   : ")); Serial.print(gps.altitude.meters()); Serial.println(F(" m"));
    Serial.print(F("Vitesse    : ")); Serial.print(gps.speed.kmph()); Serial.println(F(" km/h"));
    Serial.print(F("Satellites : ")); Serial.println(gps.satellites.value());
    Serial.print(F("Fix        : ")); Serial.println(gps.location.isValid() ? F("VALIDE") : F("NON VALIDE"));
    
    if (gps.time.isValid()) {
      Serial.print(F("Heure UTC  : "));
      if (gps.time.hour() < 10) Serial.print('0');
      Serial.print(gps.time.hour()); Serial.print(":");
      if (gps.time.minute() < 10) Serial.print('0');
      Serial.print(gps.time.minute()); Serial.print(":");
      if (gps.time.second() < 10) Serial.print('0');
      Serial.println(gps.time.second());
    } else {
      Serial.println(F("Heure invalide"));
    }

    Serial.println(F("========================"));
    Serial.println();
  }
  
  

  delay(1000);
}

unsigned long RCtime(uint8_t sensPin) {
  pinMode(sensPin, OUTPUT);
  digitalWrite(sensPin, HIGH);
  delay(1);
  unsigned long startTime = micros();
  pinMode(sensPin, INPUT);
  digitalWrite(sensPin, LOW);
  while (digitalRead(sensPin)) {
    if (micros() - startTime > 300000) break;
  }
  return micros() - startTime;
}
